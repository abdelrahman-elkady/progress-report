{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "progress-report-skill/report/v1.2.0",
  "title": "Progress Report",
  "description": "Output schema for the progress-report-skill. All timestamps are UTC ISO 8601. See REPORT_SCHEMA.md for usage notes and consumer guidance.",
  "type": "object",
  "required": [
    "generatedAt",
    "windowStart",
    "windowEnd",
    "user",
    "targetBranches",
    "weekStart",
    "workweekDays",
    "totals",
    "tickets",
    "sessions",
    "prs",
    "reviewedPrs"
  ],
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When the report was generated (UTC)"
    },
    "windowStart": {
      "type": "string",
      "format": "date-time",
      "description": "Scan window start (UTC)"
    },
    "windowEnd": {
      "type": "string",
      "format": "date-time",
      "description": "Scan window end, exclusive (UTC)"
    },
    "user": {
      "type": "string",
      "description": "GitHub login of the report subject"
    },
    "targetBranches": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Branches that count as shipped (e.g. [\"main\", \"master\"])"
    },
    "weekStart": {
      "type": ["string", "null"],
      "description": "Day-of-week if --week-start was used (e.g. \"sun\"), null otherwise"
    },
    "workweekDays": {
      "type": ["integer", "null"],
      "description": "Value of --days, null if not set"
    },
    "totals": { "$ref": "#/$defs/Totals" },
    "tickets": {
      "type": "array",
      "items": { "$ref": "#/$defs/Ticket" }
    },
    "sessions": {
      "type": "array",
      "items": { "$ref": "#/$defs/Session" }
    },
    "prs": {
      "type": "array",
      "items": { "$ref": "#/$defs/PR" }
    },
    "reviewedPrs": {
      "type": "array",
      "items": { "$ref": "#/$defs/PR" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Category": {
      "type": "string",
      "enum": [
        "implementation",
        "refactor",
        "debugging",
        "exploration",
        "planning",
        "docs",
        "review",
        "devops",
        "testing",
        "meta",
        "ask",
        "discarded",
        "other"
      ]
    },
    "CorrelationMatch": {
      "type": "object",
      "description": "A scored match linking a session to a PR (or vice versa)",
      "required": ["score", "reasons"],
      "properties": {
        "key": {
          "type": "string",
          "description": "PR key (owner/repo#number) — present in session.correlatedPRs"
        },
        "sessionId": {
          "type": "string",
          "description": "Session ID — present in pr.correlatedSessions"
        },
        "score": {
          "type": "integer",
          "minimum": 2,
          "description": "Confidence score (minimum 2 to appear)"
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Signals that contributed: branch, files(N), basename(N), jira(IDS), time"
        }
      },
      "additionalProperties": false
    },
    "Totals": {
      "type": "object",
      "required": [
        "sessions",
        "prs",
        "reviewedPrs",
        "categories",
        "sessionsByRepo",
        "prsByRepo",
        "uncorrelatedSessions",
        "minutesByRepo",
        "categoryMinutes",
        "activeMinutesByRepo",
        "activeCategoryMinutes",
        "idleMinutesByRepo",
        "idleCategoryMinutes"
      ],
      "properties": {
        "sessions": {
          "type": "integer",
          "description": "Total session count"
        },
        "prs": {
          "type": "integer",
          "description": "Authored PR count"
        },
        "reviewedPrs": {
          "type": "integer",
          "description": "Reviewed PR count"
        },
        "categories": {
          "type": "object",
          "additionalProperties": { "type": "integer" },
          "description": "Session count per category"
        },
        "sessionsByRepo": {
          "type": "object",
          "additionalProperties": { "type": "integer" },
          "description": "Session count per repoShort"
        },
        "prsByRepo": {
          "type": "object",
          "additionalProperties": { "type": "integer" },
          "description": "Authored PR count per repoShort"
        },
        "uncorrelatedSessions": {
          "type": "integer",
          "description": "Sessions with no PR match above threshold"
        },
        "minutesByRepo": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Total minutes per repoShort, sorted desc"
        },
        "categoryMinutes": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Total wall-clock minutes per category, sorted desc"
        },
        "activeMinutesByRepo": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Total active minutes per repoShort (wall-clock minus idle gaps), sorted desc"
        },
        "activeCategoryMinutes": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Total active minutes per category (wall-clock minus idle gaps), sorted desc"
        },
        "idleMinutesByRepo": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Total idle minutes per repoShort (sum of over-cap user_pause excess), sorted desc"
        },
        "idleCategoryMinutes": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Total idle minutes per category (sum of over-cap user_pause excess), sorted desc"
        },
        "minutesByDay": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/DayBucket" },
          "description": "Per-day breakdown keyed by UTC date (YYYY-MM-DD). Pre-seeded for every date in the window. Insertion order = calendar order."
        },
        "prsByDay": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/DayPR" }
          },
          "description": "PRs merged on each UTC date"
        }
      },
      "additionalProperties": false
    },
    "DayBucket": {
      "type": "object",
      "required": ["minutes", "activeMinutes", "idleMinutes", "sessions", "categories"],
      "properties": {
        "minutes": {
          "type": "number",
          "description": "Total wall-clock session minutes that day"
        },
        "activeMinutes": {
          "type": "number",
          "description": "Total active session minutes that day (wall-clock minus idle gaps)"
        },
        "idleMinutes": {
          "type": "number",
          "description": "Total idle session minutes that day (sum of over-cap user_pause excess)"
        },
        "sessions": {
          "type": "integer",
          "description": "Session count that day"
        },
        "categories": {
          "type": "object",
          "additionalProperties": { "type": "integer" },
          "description": "Session count per category that day"
        }
      },
      "additionalProperties": false
    },
    "DayPR": {
      "type": "object",
      "required": ["repo", "number", "title", "kind", "url"],
      "properties": {
        "repo": {
          "type": "string",
          "description": "repoShort"
        },
        "number": {
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["authored", "review"]
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "Session": {
      "type": "object",
      "required": [
        "sessionId",
        "filePath",
        "cwd",
        "repo",
        "repoShort",
        "gitBranch",
        "firstPrompt",
        "firstPromptShort",
        "createdAt",
        "lastActivityAt",
        "modifiedAt",
        "durationMin",
        "activeDurationMin",
        "idleSec",
        "userPauseCount",
        "longestUserPauseSec",
        "gaps",
        "segments",
        "needsActiveReview",
        "activeReviewReason",
        "userMsgCount",
        "assistantMsgCount",
        "toolCounts",
        "filesTouched",
        "filesTouchedRelative",
        "filesTouchedCount",
        "bashCmdSample",
        "userMessages",
        "assistantTexts",
        "jiraIds",
        "category",
        "needsReview",
        "reviewReason",
        "correlatedPRs"
      ],
      "properties": {
        "sessionId": {
          "type": "string",
          "description": "Unique session identifier (stem of the .jsonl filename)"
        },
        "filePath": {
          "type": "string",
          "description": "Absolute path to the source .jsonl file on the generating machine"
        },
        "cwd": {
          "type": "string",
          "description": "Working directory at session start"
        },
        "repo": {
          "type": "string",
          "description": "Full owner/repo from git remote"
        },
        "repoShort": {
          "type": "string",
          "description": "Repo name only (no owner)"
        },
        "gitBranch": {
          "type": "string",
          "description": "Git branch at session start"
        },
        "firstPrompt": {
          "type": "string",
          "description": "Full text of the first user message"
        },
        "firstPromptShort": {
          "type": "string",
          "description": "Truncated first prompt (max 200 chars)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the first user record"
        },
        "lastActivityAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last record"
        },
        "modifiedAt": {
          "type": "string",
          "format": "date-time",
          "description": "File mtime"
        },
        "durationMin": {
          "type": "number",
          "description": "Wall-clock duration in minutes (lastActivityAt - createdAt)"
        },
        "activeDurationMin": {
          "type": "number",
          "description": "Active duration in minutes. Sum of credited gap time (tool runtime + inference always fully credited; each `user_pause` gap capped at `--user-pause-cap-min`, default 10)."
        },
        "idleSec": {
          "type": "number",
          "description": "Seconds stripped from active duration because of over-cap user pauses (i.e. `sum(max(0, gap.sec - cap))` across user_pause gaps)."
        },
        "userPauseCount": {
          "type": "integer",
          "description": "Number of `user_pause` gaps observed in the session (any duration)."
        },
        "longestUserPauseSec": {
          "type": "number",
          "description": "Duration of the longest single user_pause gap, in seconds."
        },
        "gaps": {
          "type": "array",
          "items": { "$ref": "#/$defs/Gap" },
          "description": "Over-cap `user_pause` gaps (raw sec > cap). Under-cap gaps and tool_runtime/inference gaps are NOT emitted — the array would balloon. `idleSec` is reconstructible as `sum(g.sec - g.creditedSec)`."
        },
        "segments": {
          "type": "array",
          "items": { "$ref": "#/$defs/Segment" },
          "description": "Contiguous activity bursts split by over-cap gaps. Useful for timeline visualizers. Always at least one entry if the session has any activity."
        },
        "needsActiveReview": {
          "type": "boolean",
          "description": "True iff the session's active-duration calculation is worth a second look by the refinement pass (long single pause, high idle ratio, or many long pauses). Independent of `needsReview` (category review)."
        },
        "activeReviewReason": {
          "type": ["string", "null"],
          "description": "Short tag for why `needsActiveReview` is true (`long_single_pause`, `high_idle_ratio`, `many_long_pauses`). Null when `needsActiveReview` is false."
        },
        "userMsgCount": {
          "type": "integer",
          "description": "Number of user messages"
        },
        "assistantMsgCount": {
          "type": "integer",
          "description": "Number of assistant messages"
        },
        "toolCounts": {
          "type": "object",
          "additionalProperties": { "type": "integer" },
          "description": "Tool invocation counts keyed by tool name"
        },
        "filesTouched": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Absolute paths of files touched by file-editing tools"
        },
        "filesTouchedRelative": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Same paths, relative to git root"
        },
        "filesTouchedCount": {
          "type": "integer",
          "description": "Length of filesTouched"
        },
        "bashCmdSample": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Up to 8 Bash commands, each truncated to 200 chars"
        },
        "userMessages": {
          "type": "array",
          "items": { "$ref": "#/$defs/TimestampedText" }
        },
        "assistantTexts": {
          "type": "array",
          "items": { "$ref": "#/$defs/TimestampedText" }
        },
        "jiraIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Jira IDs extracted from prompts, messages, and branch name"
        },
        "category": { "$ref": "#/$defs/Category" },
        "needsReview": {
          "type": "boolean",
          "description": "True iff `category` is one of the four uncertain buckets (`other`, `discarded`, `meta`, `ask`). Signals to the optional refinement pass that this session is worth re-inspecting."
        },
        "reviewReason": {
          "type": ["string", "null"],
          "description": "Short, per-category hint describing what the heuristic was uncertain about. Non-null iff `needsReview` is true."
        },
        "correlatedPRs": {
          "type": "array",
          "items": { "$ref": "#/$defs/CorrelationMatch" },
          "description": "PRs this session contributed to, sorted by score desc"
        }
      },
      "additionalProperties": false
    },
    "PR": {
      "type": "object",
      "required": [
        "repo",
        "repoShort",
        "number",
        "title",
        "url",
        "createdAt",
        "closedAt",
        "mergedAt",
        "base",
        "head",
        "additions",
        "deletions",
        "files",
        "author",
        "jiraIds",
        "kind",
        "correlatedSessions"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "description": "Full owner/repo"
        },
        "repoShort": {
          "type": "string",
          "description": "Repo name only"
        },
        "number": {
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "createdAt": {
          "type": ["string", "null"],
          "description": "PR creation time"
        },
        "closedAt": {
          "type": ["string", "null"],
          "description": "PR close time"
        },
        "mergedAt": {
          "type": "string",
          "description": "Merge time"
        },
        "base": {
          "type": "string",
          "description": "Target branch (lowercase)"
        },
        "head": {
          "type": "string",
          "description": "Source branch"
        },
        "additions": {
          "type": "integer"
        },
        "deletions": {
          "type": "integer"
        },
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "File paths changed in the PR"
        },
        "author": {
          "type": "string",
          "description": "GitHub login of the PR author"
        },
        "jiraIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Jira IDs extracted from the PR title"
        },
        "kind": {
          "type": "string",
          "enum": ["authored", "review"],
          "description": "Whether the report subject authored or reviewed this PR"
        },
        "correlatedSessions": {
          "type": "array",
          "items": { "$ref": "#/$defs/CorrelationMatch" },
          "description": "Sessions that contributed (authored PRs only; empty for reviewed PRs)"
        }
      },
      "additionalProperties": false
    },
    "Ticket": {
      "type": "object",
      "required": ["id", "sessionIds", "prKeys", "title", "status"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Jira ticket ID (e.g. PROJ-123)"
        },
        "sessionIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prKeys": {
          "type": "array",
          "items": { "type": "string" },
          "description": "PR keys (owner/repo#number)"
        },
        "title": {
          "type": ["string", "null"],
          "description": "Jira issue summary (populated by Atlassian MCP enrichment; null otherwise)"
        },
        "status": {
          "type": ["string", "null"],
          "description": "Jira issue status (populated by enrichment; null otherwise)"
        }
      },
      "additionalProperties": false
    },
    "TimestampedText": {
      "type": "object",
      "required": ["ts", "text"],
      "properties": {
        "ts": {
          "type": "string",
          "description": "ISO 8601 timestamp"
        },
        "text": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Gap": {
      "type": "object",
      "required": ["startedAt", "endedAt", "sec", "kind", "creditedSec"],
      "properties": {
        "startedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Gap start (previous record timestamp)"
        },
        "endedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Gap end (next record timestamp)"
        },
        "sec": {
          "type": "number",
          "description": "Raw gap duration in seconds"
        },
        "kind": {
          "type": "string",
          "enum": ["user_pause", "tool_runtime", "inference", "same_turn"],
          "description": "Gap classification. Only `user_pause` gaps appear in `gaps[]`; the others are always fully credited and not emitted individually."
        },
        "creditedSec": {
          "type": "number",
          "description": "Seconds of this gap counted toward `activeDurationMin`. For over-cap `user_pause` gaps this equals the cap; `sec - creditedSec` is the stripped idle time."
        }
      },
      "additionalProperties": false
    },
    "Segment": {
      "type": "object",
      "required": ["startedAt", "endedAt", "sec", "messageCount"],
      "properties": {
        "startedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Segment start (first record timestamp in the burst)"
        },
        "endedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Segment end (last record timestamp in the burst)"
        },
        "sec": {
          "type": "number",
          "description": "Wall-clock duration of the segment in seconds"
        },
        "messageCount": {
          "type": "integer",
          "description": "Number of user+assistant records in this segment"
        }
      },
      "additionalProperties": false
    }
  }
}
